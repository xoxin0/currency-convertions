# .env.example — скопируйте в .env и заполните своими значениями
# Файл .env НЕ должен попадать в Git (добавлен в .gitignore)
# Режим отладки (True/False)
DEBUG=False
# Хост и порт
HOST=0.0.0.0
PORT=8000

# База данных
DATABASE_URL=sqlite:///./currencies.db
# Аутентификация администратора
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your_secure_password_here
# API-ключ для мобильных приложений
API_KEY=your-secret-api-key
# Секретный ключ для JWT (если будете расширять)
SECRET_KEY=your-secret-key-min-32-characters
